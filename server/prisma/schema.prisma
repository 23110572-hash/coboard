datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Board {
  id        String   @id // 5-character custom alphanumeric ID (e.g. "K9Y3X")
  purpose   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  columns   Column[]

  @@map("boards")
}

model Column {
  id        String   @id @default(uuid())
  title     String
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cards     Card[]

  @@index([boardId])
  @@map("columns")
}

model Card {
  id           String   @id @default(uuid())
  title        String
  description  String?
  labels       String?  // Comma-separated tags (e.g., "Feature,High Priority")
  assignee     String?  // Initials of assignee
  positionRank String   // Lexicographical index for sorting
  columnId     String
  column       Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([columnId, positionRank]) // Essential for fast ordering
  @@map("cards")
}
